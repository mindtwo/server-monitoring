# Credentials issued by the central monitoring dashboard.
MONITORING_PROJECT_KEY=
MONITORING_SECRET=

# Push target — leave unset for the central default endpoint.
# MONITORING_ENDPOINT=https://monitoring.mindtwo.com/api/monitoring

# Reported environment name.
MONITORING_ENVIRONMENT=production

# Optional comma-separated IPs/CIDR ranges allowed to call the pull endpoint.
# MONITORING_IP_ALLOW_LIST=203.0.113.10, 10.0.0.0/8

# Inspect another project's lockfiles/git instead of this directory.
# MONITORING_PROJECT_ROOT=/var/www/my-project
